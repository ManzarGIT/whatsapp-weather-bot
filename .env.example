# ─────────────────────────────────────────────
# WhatsApp Cloud API (Meta Developer Portal)
# ─────────────────────────────────────────────
WHATSAPP_TOKEN=your_permanent_access_token_here
WHATSAPP_PHONE_ID=your_phone_number_id_here
WHATSAPP_BUSINESS_ACCOUNT_ID=your_waba_id_here
VERIFY_TOKEN=any_random_secret_string_you_choose

# ─────────────────────────────────────────────
# OpenWeatherMap API
# https://openweathermap.org/api
# ─────────────────────────────────────────────
OPENWEATHER_API_KEY=your_openweather_api_key_here

# ─────────────────────────────────────────────
# App Config
# ─────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# Units: metric (Celsius) | imperial (Fahrenheit) | standard (Kelvin)
DEFAULT_UNITS=metric

# Cache TTL in seconds (300 = 5 minutes)
CACHE_TTL=300

# Rate limit: max requests per user per window
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW_MS=60000
